# =============================================================================
# RAFD | رفد - Environment Variables Example
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Production, set these in Vercel Dashboard:
#   Project → Settings → Environment Variables
#
# IMPORTANT: Never commit .env or .env.local to Git!
# =============================================================================

# -----------------------------------------------------------------------------
# 1) SUPABASE - REQUIRED - Core Database, Auth, Storage
# -----------------------------------------------------------------------------
# Create project at: https://supabase.com/dashboard
# Project Settings → API → Project URL + anon key + service_role key

# Frontend (Vite - exposed to browser, safe with RLS)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Backend (Vercel Serverless - api/* uses service_role)
# NEXT_PUBLIC_ must match VITE_ for API compatibility
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Server ONLY - never expose to browser, never prefix with VITE_
# Found in Supabase → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 2) GOOGLE OAUTH - OPTIONAL - For Google Sign-in
# -----------------------------------------------------------------------------
# Create OAuth Client at: https://console.cloud.google.com/apis/credentials
# Type: Web Application
# Authorized redirect URIs: https://YOUR_DOMAIN/auth/callback + http://localhost:5173/auth/callback

# Google Client ID (public, safe for frontend)
VITE_GOOGLE_CLIENT_ID=1065078894672-xxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Legacy proxy for Design Arena sandbox (DEPRECATED, leave empty for production)
# For production, use Supabase Auth Google provider directly or set to your own callback
VITE_GOOGLE_AUTH_PROXY=

# -----------------------------------------------------------------------------
# 3) SENTRY - OPTIONAL but HIGHLY RECOMMENDED for Production
# -----------------------------------------------------------------------------
# Create project at: https://sentry.io/
# Sentry → Settings → Projects → Client Keys (DSN)

# Frontend error tracking
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/1234567

# Backend error tracking (Vercel api/*)
SENTRY_DSN=https://xxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/1234567

# -----------------------------------------------------------------------------
# 4) WEB PUSH / VAPID - OPTIONAL - For browser push notifications
# -----------------------------------------------------------------------------
# Generate keys: npx web-push generate-vapid-keys

# Public key (frontend + backend)
VITE_VAPID_PUBLIC_KEY=BPxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PUBLIC_KEY=BPxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Private key (backend ONLY, server secret)
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 5) WHATSAPP CLOUD API - OPTIONAL - For sending invoices via WhatsApp Business
# -----------------------------------------------------------------------------
# Setup at: https://developers.facebook.com/apps → WhatsApp → API Setup

# Access token (long-lived)
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Alternative name supported: WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxx

# Phone Number ID from WhatsApp Cloud API dashboard
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# -----------------------------------------------------------------------------
# 6) LEGACY - DEPRECATED - Only for Design Arena sandbox migration
# -----------------------------------------------------------------------------
# These are NOT needed for new Supabase projects (rafd-dev / rafd-prod)
# Leave empty or remove after migration.

FULLSTACK_PROJECT_REF=
FULLSTACK_RESTORE_API_URL=

# -----------------------------------------------------------------------------
# 7) DEVELOPMENT / LOCAL OVERRIDES
# -----------------------------------------------------------------------------
# Vite dev server port (default 5173)
# PORT=5173

# Node environment
# NODE_ENV=development
