{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "devCommand": "npm run dev",
  "rewrites": [
    {
      "source": "/api/products",
      "destination": "/api/commerce?resource=products"
    },
    {
      "source": "/api/customers",
      "destination": "/api/commerce?resource=customers"
    },
    {
      "source": "/api/suppliers",
      "destination": "/api/commerce?resource=suppliers"
    },
    {
      "source": "/api/sales",
      "destination": "/api/transactions?resource=sales"
    },
    {
      "source": "/api/purchases",
      "destination": "/api/transactions?resource=purchases"
    },
    {
      "source": "/api/refunds",
      "destination": "/api/transactions?resource=refunds"
    },
    {
      "source": "/api/expenses",
      "destination": "/api/financial?resource=expenses"
    },
    {
      "source": "/api/bank-accounts",
      "destination": "/api/financial?resource=bank-accounts"
    },
    {
      "source": "/api/payment-terminals",
      "destination": "/api/financial?resource=payment-terminals"
    },
    {
      "source": "/api/customer-ledger",
      "destination": "/api/financial?resource=customer-ledger"
    },
    {
      "source": "/api/supplier-ledger",
      "destination": "/api/financial?resource=supplier-ledger"
    },
    {
      "source": "/api/branches",
      "destination": "/api/operations?resource=branches"
    },
    {
      "source": "/api/users",
      "destination": "/api/operations?resource=users"
    },
    {
      "source": "/api/shifts",
      "destination": "/api/operations?resource=shifts"
    },
    {
      "source": "/api/stocktakes",
      "destination": "/api/operations?resource=stocktakes"
    },
    {
      "source": "/api/invites",
      "destination": "/api/operations?resource=invites"
    },
    {
      "source": "/api/loyalty",
      "destination": "/api/features?resource=loyalty"
    },
    {
      "source": "/api/pricing",
      "destination": "/api/features?resource=pricing"
    },
    {
      "source": "/api/recipes",
      "destination": "/api/features?resource=recipes"
    },
    {
      "source": "/api/ai",
      "destination": "/api/features?resource=ai"
    },
    {
      "source": "/api/import-export",
      "destination": "/api/features?resource=import-export"
    },
    {
      "source": "/api/tenants",
      "destination": "/api/platform?resource=tenants"
    },
    {
      "source": "/api/subscription",
      "destination": "/api/platform?resource=subscription"
    },
    {
      "source": "/api/subscription-plans",
      "destination": "/api/platform?resource=subscription-plans"
    },
    {
      "source": "/api/platform-announcements",
      "destination": "/api/platform?resource=platform-announcements"
    },
    {
      "source": "/api/platform-payments",
      "destination": "/api/platform?resource=platform-payments"
    },
    {
      "source": "/api/platform-settings",
      "destination": "/api/platform?resource=platform-settings"
    },
    {
      "source": "/api/notifications",
      "destination": "/api/support?resource=notifications"
    },
    {
      "source": "/api/push",
      "destination": "/api/support?resource=push"
    },
    {
      "source": "/api/whatsapp",
      "destination": "/api/support?resource=whatsapp"
    },
    {
      "source": "/api/upload",
      "destination": "/api/support?resource=upload"
    },
    {
      "source": "/api/backups",
      "destination": "/api/support?resource=backups"
    },
    {
      "source": "/api/sync",
      "destination": "/api/support?resource=sync"
    },
    {
      "source": "/api/reports",
      "destination": "/api/analytics?resource=reports"
    },
    {
      "source": "/api/dashboard",
      "destination": "/api/analytics?resource=dashboard"
    },
    {
      "source": "/api/audit-logs",
      "destination": "/api/analytics?resource=audit-logs"
    },
    {
      "source": "/api/tenant-catalog",
      "destination": "/api/analytics?resource=tenant-catalog"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,PUT,DELETE,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, X-Tenant-Id"
        }
      ]
    }
  ],
  "functions": {
    "api/*.js": {
      "includeFiles": "api-shared/**"
    }
  }
}