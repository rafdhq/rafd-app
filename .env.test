# ------------------------------------------------------------------------------
# RAFD | رفد — Test environment (placeholders only, NO real secrets)
# ------------------------------------------------------------------------------
# Loaded automatically by Vitest (mode "test"). These dummy values let modules
# that construct a Supabase client at import time (src/lib/supabase.ts via
# import.meta.env, and api/_lib/db-client.js via process.env) initialize during
# unit/integration tests without a live project or real credentials.
#
# This file is intentionally tracked in Git (it is NOT covered by .gitignore,
# which only ignores .env / .env.local / .env.*.local) so that `npm test` is
# reproducible in any environment, including CI. Real credentials must NEVER be
# placed here — see .env.example for the production variable list.
# ------------------------------------------------------------------------------

VITE_SUPABASE_URL=https://test-placeholder.supabase.co
VITE_SUPABASE_ANON_KEY=test-placeholder-anon-key

NEXT_PUBLIC_SUPABASE_URL=https://test-placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=test-placeholder-anon-key

SUPABASE_SERVICE_ROLE_KEY=test-placeholder-service-role-key
